{
  "name": "@hooked-so/mcp",
  "version": "0.1.0",
  "description": "Hooked MCP Server — Let AI agents create videos via the Hooked API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "hooked-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "lint": "eslint src/ --ext .ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@hooked/config-typescript": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hooked-so/hooked-mcp.git"
  },
  "homepage": "https://docs.hooked.so/guides/mcp-server",
  "bugs": {
    "url": "https://github.com/hooked-so/hooked-mcp/issues"
  },
  "keywords": [
    "mcp",
    "ai-video",
    "video-api",
    "hooked",
    "model-context-protocol"
  ],
  "license": "MIT"
}
